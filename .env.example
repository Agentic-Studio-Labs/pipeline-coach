# Twenty CRM
TWENTY_API_URL=http://localhost:3000
TWENTY_API_KEY=your-twenty-api-key
# Optional: browser-facing URL for email deep links (use when TWENTY_API_URL is internal, e.g. http://twenty:3000)
# CRM_PUBLIC_URL=https://crm.yourcompany.com

# Resend (https://resend.com)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=pipeline-coach@yourdomain.com

# LLM for AI-generated actions (optional — leave commented for deterministic templates)
# Supports any LiteLLM provider: openai/gpt-4o-mini, anthropic/claude-sonnet-4-20250514, etc.
# LLM_API_KEY=your-llm-api-key
# LLM_MODEL=openai/gpt-4o-mini

# Scheduling
RUN_AT_HOUR=08

# Optional privacy controls
AUDIT_REDACT_PII=false
AUDIT_LOG_RETENTION_DAYS=30
